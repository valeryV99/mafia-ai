{
  "name": "mafia-ai",
  "private": true,
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "dev:log": "powershell -Command \"bun run dev 2>&1 | Tee-Object -FilePath server.log\"",
    "dev:server": "bun run --filter server dev",
    "dev:client": "bun run --filter client dev",
    "lint": "bunx biome check .",
    "format": "bunx biome format --write ."
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@webgpu/types": "^0.1.69",
    "client": "workspace:*",
    "unplugin-typegpu": "^0.10.2"
  },
  "dependencies": {
    "@typegpu/react": "^0.10.0-alpha.1",
    "typegpu": "^0.10.2",
    "typegpu-confetti": "^0.2.0"
  }
}
